# Copy to .env and fill in. .env is gitignored; this file is committed.

# Pinecone: https://app.pinecone.io  (API Keys)
PINECONE_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# LangSmith (optional but recommended): https://smith.langchain.com
# Leave LANGSMITH_TRACING=false to skip tracing entirely.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=linalg-rag